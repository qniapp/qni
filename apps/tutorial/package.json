{
  "name": "@qni/tutorial",
  "version": "0.0.87",
  "description": "An interactive tutorial for @qni/www.",
  "author": "@yasuhito",
  "homepage": "https://github.com/qniapp/qni#readme",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qniapp/qni.git"
  },
  "scripts": {
    "lint": "ruby -S bundle exec ruby -S rubocop",
    "start": "ruby -S bundle exec jekyll s -d ../../html --host 0.0.0.0",
    "build": "pnpm build:css && pnpm build:js",
    "build:site": "pnpm build && pnpm --dir ../.. build:site-deps && ruby -S bundle exec jekyll build -d ../../html",
    "build:js": "esbuild src/application.js --bundle --format=esm --keep-names --sourcemap --outdir=. && esbuild src/serviceworker.js --bundle --keep-names --minify --sourcemap --outdir=.",
    "build:css": "tailwindcss -c tailwind.config.js --postcss -i ./src/application.css -o ./application.css",
    "watch:js": "pnpm build:js --watch",
    "watch:css": "pnpm build:css --watch"
  },
  "bugs": {
    "url": "https://github.com/qniapp/qni/issues"
  },
  "dependencies": {
    "@qni/common": "^0.0.87",
    "@qni/elements": "^0.0.87",
    "@qni/simulator": "^0.0.87"
  },
  "eslintIgnore": [
    "application.css",
    "application.js",
    "application.js.map",
    "serviceworker.js",
    "serviceworker.js.map"
  ]
}
