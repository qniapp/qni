{
  "name": "@qni/www",
  "version": "0.0.87",
  "description": "Web service for @qni.",
  "author": "@yasuhito",
  "homepage": "https://github.com/qniapp/qni/tree/main/apps/www#readme",
  "license": "MIT",
  "keywords": [
    "quantum",
    "simulator",
    "circuit",
    "components",
    "quantum-computing",
    "quantum-computer-simulator",
    "quantum-algorithms"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yasuhito/qni.git"
  },
  "engines": {
    "node": "20.20.2"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "clean": "./bin/rails javascript:clobber",
    "dev": "./bin/dev",
    "lint": "eslint app/javascript/controllers/**/*.js app/javascript/controllers/**/*.ts app/assets/config/*.js app/assets/javascripts/serviceworker.js",
    "typecheck": "tsc --noEmit",
    "build": "pnpm build:css && pnpm build:js",
    "build:js": "pnpm exec esbuild app/javascript/application.js --bundle --keep-names --sourcemap --minify --outdir=app/assets/builds && pnpm exec esbuild app/assets/javascripts/serviceworker.js --bundle --sourcemap --minify --outdir=app/assets/builds",
    "build:css": "pnpm exec tailwindcss --postcss -i ./app/assets/stylesheets/application.tailwind.css -o ./app/assets/builds/application.css",
    "build:npm": "rollup -c && pnpm build:css && cp ./app/assets/builds/application.css dist/qni.css",
    "build:docs": "cd docs && JEKYLL_ENV=production ruby -S bundle exec jekyll build",
    "pretest": "pnpm build && pnpm build:css",
    "test": "MINITEST_REPORTER=SpecReporter ruby -S bundle exec rails test:system test",
    "test:ci": "ruby -S bundle exec rails test",
    "update-browserslist-db": "npx update-browserslist-db@latest",
    "test:watch": "pnpm test --auto-watch --no-single-run",
    "watch": "rollup -wc",
    "prerelease": "pnpm build:npm && git --no-pager diff && echo && npm pack --dry-run",
    "release": "npm publish"
  },
  "prettier": "@github/prettier-config",
  "dependencies": {
    "@hotwired/stimulus": "^3.0.1",
    "@qni/common": "^0.0.87",
    "@qni/elements": "^0.0.87",
    "@qni/simulator": "^0.0.87",
    "@svgdotjs/svg.filter.js": "^3.0.8",
    "@svgdotjs/svg.js": "^3.1.1",
    "fastdom": "^1.0.10",
    "puppeteer": "~23.2",
    "tippy.js": "^6.3.7"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.19",
    "esbuild": "^0.26.0",
    "postcss-flexbugs-fixes": "^5.0.2",
    "postcss-preset-env": "^9.1.1",
    "rollup-plugin-replace": "^2.2.0",
    "tailwindcss": "^3.3.1"
  },
  "directories": {
    "doc": "doc",
    "lib": "lib",
    "test": "test"
  },
  "files": [
    "dist"
  ],
  "gitHead": "a735e8013d45ba56fef6f3b6fcec597177f4c779"
}
